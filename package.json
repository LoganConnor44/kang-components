{
	"name": "kang-components",
	"version": "0.4.0",
	"description": "Generic, domain-free React UI primitives (CSS-first press feedback, delayed-action hook, spring presets, cross-fading text).",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LoganConnor44/kang-components.git"
	},
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"@react-spring/web": ">=9",
		"react": ">=18",
		"styled-components": ">=6"
	},
	"peerDependenciesMeta": {
		"@react-spring/web": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"styled-components": {
			"optional": true
		}
	},
	"devDependencies": {
		"@react-spring/web": "^9.7.5",
		"@types/react": "^18.3.18",
		"react": "^18.3.1",
		"styled-components": "^6.1.16",
		"typescript": "~5.6.2"
	}
}
