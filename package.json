{
	"name": "kang-components",
	"version": "0.9.4",
	"description": "Generic, domain-free React UI primitives (CSS-first press feedback, delayed-action hook, spring presets, cross-fading text, circle icon button).",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LoganConnor44/kang-components.git"
	},
	"files": [
		"dist"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"prepublishOnly": "npm run build"
	},
	"peerDependencies": {
		"@react-spring/web": ">=9",
		"@use-gesture/react": ">=10",
		"react": ">=18",
		"styled-components": ">=6"
	},
	"peerDependenciesMeta": {
		"@react-spring/web": {
			"optional": true
		},
		"@use-gesture/react": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"styled-components": {
			"optional": true
		}
	},
	"devDependencies": {
		"@react-spring/web": "^9.7.5",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@use-gesture/react": "^10.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitest/coverage-v8": "^2.1.9",
		"jsdom": "^25.0.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"styled-components": "^6.1.16",
		"typescript": "~5.6.2",
		"vitest": "^2.1.8"
	}
}
